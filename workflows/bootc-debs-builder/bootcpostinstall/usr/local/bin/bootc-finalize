#!/bin/bash
#
# bootc-finalize - finalize the bootc image's kernel and bootloader layout.
# Moves the newest kernel into /usr/lib/modules/<kver>, regenerates the
# initramfs with dracut, and stages the signed shim/GRUB EFI binaries where
# bootupd expects them. Invoked from the bootc package postinst during build.
set -euo pipefail

# ls -1v version-sorts to select the newest kernel; find cannot sort by version.
# shellcheck disable=SC2012
KVER=$(ls -1v /usr/lib/modules 2>/dev/null | tail -1)
[ -z "${KVER}" ] && exit 0

# Support both Debian-standard kernels (in /boot/vmlinuz-${KVER}) and kernels
# already placed in /usr/lib/modules/${KVER}/vmlinuz (e.g. Proxmox pve-kernel
# or other downstream images).
if [ -f "/boot/vmlinuz-${KVER}" ]; then
  mv "/boot/vmlinuz-${KVER}" "/usr/lib/modules/${KVER}/vmlinuz"
elif [ ! -f "/usr/lib/modules/${KVER}/vmlinuz" ]; then
  # Kernel absent from both locations: nothing to do.
  exit 0
fi

# Dracut.
# NOTE: The order below is intentional and optimized for the bootc layer:
#   1. Move the kernel to its final location in /usr/lib/modules.
#   2. Purge /boot entirely to ensure no stale files remain.
#   3. Generate a fresh initramfs with dracut.
# If dracut fails, set -euo pipefail aborts the entire build, preventing a
# partially-broken image from being produced. This is NOT a bug - it is the
# correct failure mode for atomic images.
# /boot is a fixed literal (never a variable), so this cannot expand to /*.
# shellcheck disable=SC2115
rm -rf /boot/*
dracut --kver "${KVER}" --force "/usr/lib/modules/${KVER}/initramfs.img"

# Structure for bootupd.
# This block is idempotent / re-entrant: the base image stages the shim and
# GRUB EFI binaries here once, consuming the package-provided sources with `mv`.
# A downstream rebuild (e.g. Proxmox-Atomic swapping in the pve-kernel) re-runs
# bootc-finalize only to relocate its kernel and regenerate the initramfs; the
# EFI binaries are already staged in /usr/lib/efi and carried forward, so their
# sources are gone. Each staging step below is therefore guarded on its source
# still being present. On the base build every source exists, so behaviour is
# byte-identical to before; downstream it simply skips the already-staged EFI.
SHIM_VER=$(dpkg-query -W -f='${Version}' shim-signed)
GRUB_VER=$(dpkg-query -W -f='${Version}' grub-efi-amd64-signed)

mkdir -p \
  "/usr/lib/efi/shim/${SHIM_VER}/EFI/BOOT" \
  "/usr/lib/efi/shim/${SHIM_VER}/EFI/debian" \
  "/usr/lib/efi/grub2/${GRUB_VER}/EFI/debian"

# GRUB EFI binary - custom Fedora build with blscfg embedded.
if [ -f /usr/lib/grub/x86_64-efi-signed/grubx64.efi.signed ]; then
  mv /usr/lib/grub/x86_64-efi-signed/grubx64.efi.signed \
    "/usr/lib/efi/grub2/${GRUB_VER}/EFI/debian/grubx64.efi"
fi

# Shim in BOOT/ for UEFI firmware.
if [ -f /usr/lib/shim/shimx64.efi.signed ]; then
  mv /usr/lib/shim/shimx64.efi.signed \
    "/usr/lib/efi/shim/${SHIM_VER}/EFI/BOOT/BOOTX64.EFI"
fi

# Shim also in vendor dir - bootupd looks for shimx64.efi there.
if [ -f "/usr/lib/efi/shim/${SHIM_VER}/EFI/BOOT/BOOTX64.EFI" ]; then
  cp "/usr/lib/efi/shim/${SHIM_VER}/EFI/BOOT/BOOTX64.EFI" \
    "/usr/lib/efi/shim/${SHIM_VER}/EFI/debian/shimx64.efi"
fi

# Fallback and MokManager.
if [ -f /usr/lib/shim/fbx64.efi.signed ]; then
  mv /usr/lib/shim/fbx64.efi.signed \
    "/usr/lib/efi/shim/${SHIM_VER}/EFI/BOOT/fbx64.efi"
fi
if [ -f /usr/lib/shim/mmx64.efi.signed ]; then
  mv /usr/lib/shim/mmx64.efi.signed \
    "/usr/lib/efi/shim/${SHIM_VER}/EFI/BOOT/mmx64.efi"
fi

bootupctl backend generate-update-metadata /

# Brand the shim fallback's boot entry with the product name so the firmware
# NVRAM entry matches this image instead of a hardcoded distro. fbx64 reads
# BOOTX64.CSV (UTF-16LE: "shimx64.efi,<label>,,<description>") to (re)create the
# entry. The product name is injected at build time (PRODUCT_NAME build-arg ->
# /usr/lib/bootc/product-name); we fall back to os-release NAME, then "Linux".
# Written after generate-update-metadata so it is not regenerated away, into the
# vendor dir bootupd lays onto the ESP. Runs in every image (base + any
# downstream) via the autonomous finalize, so each brands its own entry.
if [ -d "/usr/lib/efi/shim/${SHIM_VER}/EFI/debian" ]; then
  product=$(cat /usr/lib/bootc/product-name 2>/dev/null || true)
  if [ -z "${product}" ]; then
    product=$(. /etc/os-release 2>/dev/null && printf '%s' "${NAME:-Linux}")
  fi
  printf 'shimx64.efi,%s,,This is the boot entry for %s\n' "${product}" "${product}" \
    | iconv -f UTF-8 -t UTF-16LE \
      > "/usr/lib/efi/shim/${SHIM_VER}/EFI/debian/BOOTX64.CSV"
fi
