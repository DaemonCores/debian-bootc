#!/bin/bash
# firstboot-user-setup
# First-boot TUI for user account and root password setup.
# Launched by firstboot-user-setup.service before getty@tty1.
# Modeled after Raspberry Pi OS userconfig.service.
set -euo pipefail

FLAG=/var/lib/firstboot-user-setup.done

# Bug-fix 3: in ExecStartPre context, ConditionPathExists is not evaluated — check the flag here
[[ -f "$FLAG" ]] && exit 0

# Skip if a regular user already exists (UID 1000-65533)
_existing_user() {
    while IFS=: read -r _ _ uid _; do
        if [[ "$uid" -ge 1000 && "$uid" -le 65533 ]]; then
            return 0
        fi
    done < /etc/passwd
    return 1
}

if _existing_user; then
    touch "$FLAG"
    exit 0
fi

# Grab TTY1
exec </dev/tty1 >/dev/tty1 2>/dev/tty1
# Bug-fix 1: TERM is not injected by systemd in ExecStartPre — whiptail/ncurses crashes without it
export TERM=linux
clear

# Build display name from /etc/hostname (e.g. my-system -> My System)
# cut -d. -f1: strip the domain if a FQDN was set (e.g. host.local → host)
DISPLAY_NAME=$(
    cat /etc/hostname \
    | cut -d. -f1 \
    | tr -d '\n' \
    | tr -- '-_' ' ' \
    | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1))substr($i,2)}1' \
    | tr -s ' '
)

# whiptail helpers
_title="Setup -- ${DISPLAY_NAME}"
_input() { whiptail --title "$_title" --inputbox    "$1" 10 60 "${2:-}" 3>&1 1>&2 2>&3; }
_pass()  { whiptail --title "$_title" --passwordbox  "$1" 10 60          3>&1 1>&2 2>&3; }
_yesno() { whiptail --title "$_title" --yesno        "$1" 12 65; }
_msg()   { whiptail --title "$_title" --msgbox        "$1" 12 65; }

# Welcome
_msg "Welcome to ${DISPLAY_NAME}!\n\nThis wizard will create your user account.\nPress Enter to continue."

# ── System language (locale) ──────────────────────────────────────────────
# Bug-fix 2: dpkg-reconfigure may return non-zero (locale already set, missing package) — || true prevents abort
dpkg-reconfigure locales || true

# ── Keyboard layout ───────────────────────────────────────────────────────
dpkg-reconfigure keyboard-configuration || true
setupcon || true

# ── Hostname (required) ──────────────────────────────────────────────────
CURRENT_HOSTNAME=$(cat /etc/hostname | cut -d. -f1 | tr -d '\n')
while true; do
    NEWHOSTNAME=$(_input "Hostname:" "$CURRENT_HOSTNAME" || true)
    [[ -z "$NEWHOSTNAME" ]] && { _msg "Hostname cannot be empty."; continue; }
    [[ "$NEWHOSTNAME" =~ ^[a-zA-Z0-9]([a-zA-Z0-9-]{0,61}[a-zA-Z0-9])?$ ]] || {
        _msg "Invalid hostname.\nAllowed: letters, digits, hyphens\n(must start and end with a letter or digit, max 63 chars)"
        continue
    }
    break
done
# Update wizard title with the new hostname
DISPLAY_NAME=$(echo "$NEWHOSTNAME" | tr -- '-' ' ' | awk '{for(i=1;i<=NF;i++) $i=toupper(substr($i,1,1))substr($i,2)}1')
_title="Setup -- ${DISPLAY_NAME}"

# ── Username ──────────────────────────────────────────────────────────────
while true; do
    USERNAME=$(_input "Username:" "" || true)
    [[ -z "$USERNAME" ]] && { _msg "Username cannot be empty."; continue; }
    [[ "$USERNAME" =~ ^[a-z_][a-z0-9_-]{0,31}$ ]] || {
        _msg "Invalid username.\nAllowed: lowercase letters, digits, - or _\n(must start with a letter or _)"
        continue
    }
    getent passwd "$USERNAME" &>/dev/null && { _msg "User '${USERNAME}' already exists."; continue; }
    break
done

# ── Full name (optional) ──────────────────────────────────────────────────
FULLNAME=$(_input "Full name (optional, Enter to skip):" "" || echo "")

# ── User password ─────────────────────────────────────────────────────────
while true; do
    PASS1=$(_pass "Password for '${USERNAME}':" || true)
    [[ ${#PASS1} -lt 8 ]] && { _msg "Password must be at least 8 characters."; continue; }
    PASS2=$(_pass "Confirm password:" || true)
    [[ "$PASS1" == "$PASS2" ]] && break
    _msg "Passwords do not match."
done

# ── Root password (required) ─────────────────────────────────────────────
ROOT_PASS=""
while true; do
    ROOT_PASS=$(_pass "Root password (required):" || true)
    [[ ${#ROOT_PASS} -lt 8 ]] && { _msg "Password must be at least 8 characters."; continue; }
    ROOT2=$(_pass "Confirm root password:" || true)
    [[ "$ROOT_PASS" == "$ROOT2" ]] && break
    _msg "Passwords do not match."
done

# ── Sudo privileges ───────────────────────────────────────────────────────
IS_SUDOER=no
_yesno "Grant sudo privileges to '${USERNAME}'?\n\n(Allows running commands as root with sudo)" && IS_SUDOER=yes || true

# ── SSH root login ────────────────────────────────────────────────────────
SSH_ROOT=no
_yesno "Allow root SSH login with password?\n\n[!] Not recommended for production." && SSH_ROOT=yes || true

# ── Confirmation ──────────────────────────────────────────────────────────
SUMMARY="Summary:\n\n"
SUMMARY+="  Hostname  : ${NEWHOSTNAME}\n"
SUMMARY+="  User      : ${USERNAME}\n"
[[ -n "$FULLNAME" ]] && SUMMARY+="  Full name : ${FULLNAME}\n"
SUMMARY+="  Sudo      : ${IS_SUDOER}\n"
SUMMARY+="  Root pwd  : set\n"
SUMMARY+="  SSH root  : ${SSH_ROOT}\n\nConfirm?"
_yesno "$SUMMARY" || { _msg "Setup cancelled. Wizard will re-run on next boot."; exit 0; }

# ── Apply hostname ────────────────────────────────────────────────────────
hostnamectl set-hostname "$NEWHOSTNAME"

# ── Create user ───────────────────────────────────────────────────────────
useradd \
    --home-dir  "/home/${USERNAME}" \
    --shell     /bin/bash \
    --comment   "${FULLNAME:-$USERNAME}" \
    --create-home \
    "$USERNAME"

# Use printf to avoid echo interpreting special characters in the password
printf '%s:%s\n' "$USERNAME" "$PASS1" | chpasswd

# ── Root password (required) ─────────────────────────────────────────────
printf 'root:%s\n' "$ROOT_PASS" | chpasswd
# Clear the forced expiry set by the kickstart (chage -d 0) now that the user has set their password
chage -d "$(date +%Y-%m-%d)" root

# ── Standard Debian groups ────────────────────────────────────────────────
for grp in adm systemd-journal cdrom audio video plugdev netdev; do
    getent group "$grp" &>/dev/null && usermod -aG "$grp" "$USERNAME" || true
done
[[ "$IS_SUDOER" == yes ]] && usermod -aG sudo "$USERNAME"

# ── SSH root login config ─────────────────────────────────────────────────
mkdir -p /etc/ssh/sshd_config.d
if [[ "$SSH_ROOT" == yes ]]; then
    echo "PermitRootLogin yes" > /etc/ssh/sshd_config.d/01-permitrootlogin.conf
else
    echo "PermitRootLogin no"  > /etc/ssh/sshd_config.d/01-permitrootlogin.conf
fi

touch "$FLAG"
_msg "User '${USERNAME}' created successfully!\n\nYou can now log in."

# ── Reset terminal and hand control back to getty ─────────────────────────
stty sane
clear
