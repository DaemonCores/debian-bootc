+/// Debian equivalent of `query_files`: resolve the dpkg package(s) owning the
+/// given files and record their names, versions and a metadata timestamp.
+fn query_files_dpkg<T>(paths: impl IntoIterator<Item = T>) -> Result<ContentMetadata>
+where
+    T: AsRef<Path>,
+{
+    let mut names: BTreeSet<String> = BTreeSet::new();
+    for p in paths {
+        let path = p.as_ref();
+        let out = std::process::Command::new("dpkg-query")
+            .arg("--search")
+            .arg(path)
+            .output()?;
+        if !out.status.success() {
+            std::io::stderr().write_all(&out.stderr)?;
+            bail!("Failed to invoke dpkg-query --search {:?}", path);
+        }
+        // Output lines look like "pkg: /the/path"; take the owning package.
+        let stdout = String::from_utf8(out.stdout)?;
+        let owner = stdout
+            .lines()
+            .find_map(|l| l.split_once(": ").map(|(pkg, _)| pkg))
+            .map(|pkg| pkg.split(',').next().unwrap_or(pkg).trim().to_string())
+            .ok_or_else(|| anyhow::anyhow!("No dpkg owner for {:?}", path))?;
+        names.insert(owner);
+    }
+    if names.is_empty() {
+        bail!("Failed to find any dpkg packages matching the given files");
+    }
+
+    let mut modules: Vec<Module> = Vec::new();
+    let mut version_parts: Vec<String> = Vec::new();
+    for name in &names {
+        let out = std::process::Command::new("dpkg-query")
+            .args(["-W", "-f=${Version}"])
+            .arg(name)
+            .output()?;
+        if !out.status.success() {
+            std::io::stderr().write_all(&out.stderr)?;
+            bail!("Failed to query version of dpkg package {name}");
+        }
+        let version = String::from_utf8(out.stdout)?.trim().to_string();
+        version_parts.push(format!("{name}-{version}"));
+        modules.push(Module {
+            name: name.clone(),
+            rpm_evr: version,
+        });
+    }
+    modules.sort_unstable();
+
+    Ok(ContentMetadata {
+        timestamp: crate::util::get_metadata_timestamp()?,
+        version: version_parts.join(","),
+        versions: Some(modules),
+    })
+}
