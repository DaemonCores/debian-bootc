#!/bin/bash
set -euo pipefail

grep -q "^# ifupdown2-autoconf" /etc/network/interfaces || exit 0

IFACE=$(ip -o link show | awk -F': ' '/ether/{print $2; exit}')
[ -z "$IFACE" ] && exit 0

# Probe for a DHCPv6 server before writing the config. The "inet6 auto" stanza
# is added only when a server actually answers; otherwise ifup would spawn a
# dhclient -6 that hangs (30s timeout, networking.service failure) on networks
# whose RA requests DHCPv6 with no server. Kernel SLAAC still provides IPv6
# addressing regardless, so IPv6 keeps working even without the stanza.
ip link set "$IFACE" up 2>/dev/null || true
IPV6_STANZA=""
if timeout 5 dhclient -6 -1 -q \
    -pf /run/dhcp6-probe.pid -lf /run/dhcp6-probe.leases "$IFACE" >/dev/null 2>&1; then
  IPV6_STANZA="iface ${IFACE} inet6 auto
    dns-nameservers 2a07:e340::2 2606:4700:4700::1111"
fi
dhclient -6 -x -pf /run/dhcp6-probe.pid "$IFACE" >/dev/null 2>&1 || true
rm -f /run/dhcp6-probe.pid /run/dhcp6-probe.leases

cat > /etc/network/interfaces << EOF
# ifupdown2-autoconf: auto-configured on boot, remove this line to disable
source /etc/network/interfaces.d/*

auto lo
iface lo inet loopback

auto ${IFACE}
iface ${IFACE} inet dhcp
    dns-nameservers 194.242.2.2 1.1.1.1
${IPV6_STANZA}
EOF