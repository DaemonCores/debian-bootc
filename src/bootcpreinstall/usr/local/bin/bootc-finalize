#!/bin/bash
set -euo pipefail

KVER=$(ls -1v /usr/lib/modules | tail -1)

# Dracut
cp /boot/vmlinuz-${KVER} /usr/lib/modules/${KVER}/vmlinuz
rm -rf /boot/*
dracut --kver "${KVER}" --force /usr/lib/modules/${KVER}/initramfs.img

# Structure bootupd
mkdir -p \
    /usr/lib/bootupd/updates/EFI/BOOT \
    /usr/lib/bootupd/updates/EFI/debian \
    /usr/lib/bootupd/grub2-static/configs

ln -sf /usr/lib/shim/shimx64.efi.signed \
    /usr/lib/bootupd/updates/EFI/BOOT/BOOTX64.EFI
ln -sf /usr/lib/grub/x86_64-efi-signed/grubx64.efi.signed \
    /usr/lib/bootupd/updates/EFI/debian/grubx64.efi

printf 'insmod blscfg\nblscfg\n' \
    > /usr/lib/bootupd/grub2-static/configs/grub.cfg
printf 'insmod blscfg\nblscfg\n' \
    > /usr/lib/bootupd/updates/EFI/debian/grub.cfg