127.0.0.1   localhost.localdomain localhost

# The following lines are desirable for IPv6 capable hosts
::1     ip6-localhost ip6-loopback
fe00::0 ip6-localnet
ff00::0 ip6-mcastprefix
ff02::1 ip6-allnodes
ff02::2 ip6-allrouters
ff02::3 ip6-allhosts

# PVE
# Bootstrap entry so the baked default hostname resolves to a non-loopback-only
# address BEFORE networking/domain-set runs. pmxcfs needs the local hostname to
# resolve to create /etc/pve/nodes/<host> and generate pve-ssl.pem, and it
# starts during multi-user boot — earlier than networking.service ExecStartPost
# (domain-set) and earlier than the first-boot wizard. domain-set rewrites this
# line to the real global IPv4 once the WAN interface has a lease; the first-boot
# wizard renames the host and the node is renamed on the next boot.
127.0.1.1   daemoncores-ve.local daemoncores-ve
